{
  "title": "Policy-as-Detection Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Active Policy Failures",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(kyverno_policy_results_total{rule_result=\"fail\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Failures by Policy",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum by (policy_name) (kyverno_policy_results_total{rule_result=\"fail\"})",
          "legendFormat": "{{ policy }}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Failures by Namespace",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (resource_namespace, policy_name) (kyverno_policy_results_total{rule_result=\"fail\"})",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}

